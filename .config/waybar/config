{
  "layer": "top",
  // Using margin-bottom with a negative value in order to reduce the space between Hyprland window and waybar
  "margin-bottom": 0,
  "margin-top": 10,
  "margin-left": 10,
  "margin-right": 10,
  "modules-left": ["custom/launcher", "cpu", "memory", "network", "tray"],
  "modules-center": [],
  "modules-right": [
    "custom/keyboard-layout-work",
    "custom/keyboard-layout-home",
    "pulseaudio",
    "clock",
    "battery",
    "custom/power"
  ],
  "pulseaudio": {
    "tooltip": false,
    "scroll-step": 5,
    "format": "{icon} {volume}%",
    "format-muted": "о»Ё {volume}%",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "format-icons": {
      "default": ["пҖҰ", "пҖ§", "пҖЁ"]
    }
  },
  "network": {
    "format-wifi": "пҮ« {ipaddr}/{cidr}",
    "format-ethernet": "оҪ„ {ipaddr}/{cidr}",
    "tooltip-format": "{essid} ({signalStrenvvvvvvvgth}%)",
    "format-linked": "{ifname} (No IP) уұҳ–",
    "format-disconnected": "о«җ",
    "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 20
    },
    "format": "{icon} {capacity}%",
    "format-charging": "у°Ӯ„ {capacity}%",
    "format-plugged": "пҮҰ {capacity}%",
    "format-alt": "{time} {icon}",
    "format-icons": ["пү„", "пүғ", "пүӮ", "пүҒ", "пүҖ"]
  },
  "tray": {
    "icon-size": 18,
    "spacing": 10
  },
  "clock": {
    "format": "{:у°Ҙ” %I:%M %p  пҒі %d/%m/%Y}"
  },
  "cpu": {
    "interval": 5,
    "format": "п’ј {}%"
  },
  "memory": {
    "interval": 5,
    "format": "оҝ… {}%"
  },
  "custom/keyboard-layout-home": {
    "tooltip": false,
    "format": "п„ң {}",
    "exec": "hyprctl devices | grep \"royuan-keydous-nj80-ap500$\" -A 3 | grep \"active keymap\" | cut -f3 -d \" \"",
    "interval": 1
  },
  "custom/keyboard-layout-work": {
    "tooltip": false,
    "format": "п„ң {}",
    "exec": "hyprctl devices | grep \"keychron-keychron-v1$\" -A 3 | grep \"active keymap\" | cut -f3 -d \" \"",
    "interval": 1
  },
  "custom/launcher": {
    "format": "п„ө",
    "on-click": "wofi --show drun",
    "on-click-right": "killall rofi"
  },
  "custom/power": {
    "format": "вҸ»",
    "on-click": "wlogout --protocol layer-shell -b 4"
  },
  // The code following below is given in the great documentation for Waybar status bar under Useful Utilities in Hyprland wiki
  "hyrpland/workspaces": {
    "format": "{icon}",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "on-click": "activate"
  }
}
